// ============================================================
//  Firebase Firestore Security Rules
//  Paste this in: Firebase Console → Firestore → Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Products ----
    // Anyone authenticated can READ products
    // Only the admin can CREATE, UPDATE, DELETE
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == "YOUR_ADMIN_UID_HERE";
    }

    // ---- Users ----
    // A user can read/write their own document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
